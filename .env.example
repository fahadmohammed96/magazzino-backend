# Variabili d'ambiente del servizio magazzino-api.
# Copia questo file in `.env` e valorizza le variabili. NON versionare `.env`
# né inserire qui valori reali: solo nomi e descrizioni.

# DSN SQLAlchemy verso PostgreSQL, con driver psycopg 3 (schema
# `postgresql+psycopg://`). Formato:
#   postgresql+psycopg://<UTENTE>:<PASSWORD>@<HOST>:<PORTA>/<NOME_DB>
# Obbligatoria: senza questa variabile il servizio non si avvia.
# Valorizzala nel tuo file `.env` locale (non versionato), mai qui.
DATABASE_URL=

# --- Autenticazione ---

# Chiave segreta per firmare i token di accesso (JWT, HS256). Obbligatoria.
# Usa una stringa lunga e casuale, es. generata con:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Segreto: mai un valore reale in questo file.
AUTH_SECRET_KEY=

# Durata di validità del token di accesso, in minuti. Opzionale (default: 60).
ACCESS_TOKEN_EXPIRE_MINUTES=

# --- Seed dell'admin iniziale (solo per `python -m app.db.seed`) ---
# Credenziali del primo utente admin, create una tantum per il primo accesso.
# Il seed viene eseguito solo se entrambe sono valorizzate. La password è un
# segreto: mai un valore reale qui.
SEED_ADMIN_USERNAME=
SEED_ADMIN_PASSWORD=

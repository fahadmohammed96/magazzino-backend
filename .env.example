# Variabili d'ambiente del servizio magazzino-api.
# Copia questo file in `.env` e valorizza le variabili. NON versionare `.env`
# né inserire qui valori reali: solo nomi e descrizioni.

# DSN SQLAlchemy verso PostgreSQL, con driver psycopg 3 (schema
# `postgresql+psycopg://`). Formato:
#   postgresql+psycopg://UTENTE:PASSWORD@HOST:PORTA/NOME_DB
# Esempio locale (sostituisci con le tue credenziali):
#   postgresql+psycopg://magazzino:CAMBIAMI@localhost:5432/magazzino
DATABASE_URL=
